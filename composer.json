{
    "name": "innis/nostr-relay",
    "description": "AMPHP-based async WebSocket relay server for Nostr protocol",
    "type": "library",
    "license": "MIT",
    "keywords": ["nostr", "protocol", "relay", "websocket", "amphp", "async"],
    "authors": [
        {
            "name": "John Innis",
            "email": "john@innis.xyz",
            "homepage": "https://www.innis.xyz/"
        }
    ],
    "require": {
        "php": "^8.3",
        "amphp/amp": "^3.0",
        "amphp/http-server": "^3.0",
        "amphp/websocket-server": "^4.0",
        "innis/nostr-core": "^0.3",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.85",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Innis\\Nostr\\Relay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Innis\\Nostr\\Relay\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "phpunit",
            "@analyse"
        ],
        "test-unit": "phpunit --testsuite=Unit",
        "test-coverage": "XDEBUG_MODE=coverage phpunit --coverage-html var/tests/coverage/html --coverage-text --coverage-clover var/tests/coverage/clover.xml",
        "analyse": "phpstan analyse",
        "fix-style": "php-cs-fixer fix",
        "check-style": "php-cs-fixer fix --dry-run --diff"
    },
    "config": {
        "sort-packages": true
    }
}
